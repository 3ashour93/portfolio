---
import Layout from '../layouts/Layout.astro';
import { PROFILE, PROJECTS, CLIENTS, CATEGORIES } from '../data/projects';
---

<Layout title="Omar Ashour — Creative Director & Brand Designer">

<!-- ══ HERO ══════════════════════════════════ -->
<section id="hero">
  <div class="h-content">
    <div class="h-name-row">
      <span class="h-name h-name-l">Omar</span>
      <span class="h-name h-name-r">Ashour</span>
    </div>
    <div class="h-foot">
      <div class="h-foot-col">
        <div class="h-desc">Creative Director<br>Doha, Qatar</div>
        <a class="h-cta" href="#work">View Work</a>
      </div>
      <div class="h-foot-col h-foot-right">
        <div class="h-desc">Brand · Identity<br>& Digital</div>
        <a class="h-cta" href="/Omar-Ashour-Portfolio-2026.pdf" download>Download Portfolio</a>
      </div>
    </div>
  </div>
  <div class="h-scroll">
    <div class="h-scroll-bar"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- ══ WORK ══════════════════════════════════ -->
<section class="sec" id="work">
  <div class="sec-head r">
    <div>
      <div class="sec-label">Selected Work</div>
    </div>
    <span class="sec-meta">Brand · Identity · Digital</span>
  </div>

  <div class="work-layout r">
    <div id="cat-filter" class="cat-filter">
      {CATEGORIES.map((c) => (
        <button class={`cat-pill${c === 'All' ? ' is-active' : ''}`} data-cat={c}>{c}</button>
      ))}
    </div>

    <div id="proj-grid" class="proj-text-grid">
      {PROJECTS.map((p) => {
        const cats = (p.categories && p.categories.length ? p.categories : [p.category]).join('||');
        return (
          <a class="proj-item" href={`/projects/${p.id}`} data-hero={p.heroImage} data-cats={cats}>
            <svg class="pi-border" preserveAspectRatio="none" aria-hidden="true">
              <rect class="pi-border-rect" x="0" y="0" width="100%" height="100%" fill="none" />
            </svg>
            <div class="pi-inner">
              <div class="pi-num">{p.num}</div>
              <div class="pi-content">
                <div class="pi-cat">{p.category}</div>
                <div class="pi-title">{p.title}</div>
                <div class="pi-meta">{p.client}</div>
                {p.badge && <div class="pi-badge">{p.badge}</div>}
              </div>
              <div class="pi-year">{p.year}</div>
              <div class="pi-arr">→</div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<!-- Preview bubble -->
<div id="preview">
  <div class="pv-fallback">
    <div class="pv-num" id="pvNum"></div>
  </div>
</div>

<!-- ══ ABOUT ══════════════════════════════════ -->
<section class="sec sec-inv" id="about">
  <div class="sec-head r">
    <div>
      <div class="sec-label">About</div>
      <h2 class="sec-title">Brand director.<br><em>Doha-based.</em></h2>
    </div>
  </div>
  <div class="about-grid">
    <div class="ab-left r">
      <p class="ab-tagline">8 years. Governments, federations, and institutions across the region.</p>
      <div class="ab-body">
        <p>I direct brand strategy and visual identity for organisations where the work actually matters. Institutional communications, major events, and digital products — built to last and built to scale.</p>
        <p>Recent work includes the <strong>Doha Legal Forum 2026</strong> identity signed off by Qatar's Minister of Justice, the <strong>SIFoCC</strong> conference brand for the world's largest gathering of commercial courts, and broadcast graphics for the <strong>AFC Asian Cup</strong>.</p>
        <p>MSc Digital Media Design, University of Edinburgh · BSc Media & Communications, Northwestern University in Qatar · Minor in Computer Science, Carnegie Mellon University in Qatar.</p>
      </div>
      <div class="ab-tags r d1">
        <span class="ab-tag">Brand Identity</span>
        <span class="ab-tag">Creative Direction</span>
        <span class="ab-tag">UI / UX</span>
        <span class="ab-tag">Motion Design</span>
        <span class="ab-tag">AR / VR</span>
        <span class="ab-tag">Creative Coding</span>
        <span class="ab-tag">Event Branding</span>
        <span class="ab-tag">Editorial</span>
      </div>
      <div class="ab-downloads r d2">
        <a class="ab-dl" href="/Omar-Ashour-Portfolio-2026.pdf" download>
          <span class="ab-dl-icon">↓</span> Portfolio PDF
        </a>
        <a class="ab-dl" href="/Omar-Ashour-Resume.docx" download>
          <span class="ab-dl-icon">↓</span> Resume
        </a>
      </div>
    </div>
    <div class="ab-right r d1">
      <div class="ab-facts">
        <div class="ab-fact">
          <span class="ab-fact-k">Based in</span>
          <span class="ab-fact-v">{PROFILE.location}</span>
        </div>
        <div class="ab-fact">
          <span class="ab-fact-k">Experience</span>
          <span class="ab-fact-v">8+ Years</span>
        </div>
        <div class="ab-fact">
          <span class="ab-fact-k">Current Role</span>
          <span class="ab-fact-v">Senior Branding Specialist<br>QICDRC</span>
        </div>
        <div class="ab-fact">
          <span class="ab-fact-k">Education</span>
          <span class="ab-fact-v">MSc Digital Media Design<br>University of Edinburgh</span>
        </div>
        <div class="ab-fact">
          <span class="ab-fact-k">Languages</span>
          <span class="ab-fact-v">English · Arabic · French</span>
        </div>
        <div class="ab-fact">
          <span class="ab-fact-k">Availability</span>
          <span class="ab-fact-v av">
            <span class="av-dot" aria-hidden="true"></span>
            <span class="av-text">{PROFILE.available ? 'Open to projects' : 'Not available'}</span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ CLIENTS ══════════════════════════════════ -->
<section class="sec" id="clients">
  <div class="sec-head r">
    <div>
      <div class="sec-label">Clients</div>
      <h2 class="sec-title">Who I've<br><em>worked with.</em></h2>
    </div>
    <span class="sec-meta">{CLIENTS.length} organisations</span>
  </div>

  <div class="cl-text-grid r">
    {CLIENTS.map((c, i) => (
      <div class="cl-text-item">
        <div class="cl-n">0{i + 1}</div>
        <div class="cl-name">{c.name}</div>
        <div class="cl-type">{c.type}</div>
      </div>
    ))}
  </div>
</section>

<!-- ══ CONTACT ══════════════════════════════════ -->
<section id="contact">
  <div class="ct-inner">
    <div class="ct-left r">
      <div class="sec-label">Contact</div>
      <div class="ct-big">
        Available.<br>Let's<br><em>talk.</em>
      </div>
    </div>
    <div class="ct-right r d1">
      <a class="ct-row" href={`mailto:${PROFILE.email}`}>
        <span class="ct-k">Email</span>
        <span class="ct-a">↗</span>
      </a>
      <a class="ct-row" href={PROFILE.links.linkedin} target="_blank" rel="noopener">
        <span class="ct-k">LinkedIn</span>
        <span class="ct-a">↗</span>
      </a>
      <a class="ct-row" href={PROFILE.links.behance} target="_blank" rel="noopener">
        <span class="ct-k">Behance</span>
        <span class="ct-a">↗</span>
      </a>
      <a class="ct-row" href={PROFILE.links.vimeo} target="_blank" rel="noopener">
        <span class="ct-k">Vimeo</span>
        <span class="ct-a">↗</span>
      </a>
    </div>
  </div>
</section>

</Layout>

<style>
/* ── HERO ── */
#hero {
  height: 100svh; min-height: 560px;
  background: var(--paper);
  position: relative; overflow: hidden;
}
/* Scroll-driven dark sweep — same style as project row hover */
#hero::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--ink);
  transform: scaleX(var(--hero-sweep, 0));
  transform-origin: left;
  z-index: 0;
  will-change: transform;
}
.h-content {
  position: relative; z-index: 1;
  height: 100%;
  display: flex; flex-direction: column;
  justify-content: flex-end;
  padding: 0 var(--pad-x) clamp(40px, 6vh, 80px);
}
.h-name-row {
  position: absolute;
  left: 0; right: 0;
  bottom: calc(clamp(40px, 6vh, 80px) + clamp(60px, 9vh, 100px));
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: clamp(16px, 2.5vw, 40px);
  pointer-events: none;
  z-index: 2;
}
.h-name {
  font-family: var(--f-ser);
  font-size: clamp(4.5rem, 11.5vw, 13rem);
  font-weight: 300; line-height: .86; letter-spacing: -.03em;
  user-select: none;
  transition: color .6s var(--ease);
}
.h-name-l {
  color: var(--ink);
  animation: up .9s var(--ease) .2s both;
}
.h-name-r {
  color: rgba(10,10,10,.3);
  font-style: italic;
  animation: up .9s var(--ease) .25s both;
}
/* Swept state — text inverts when dark bg is behind */
#hero.h-swept .h-name-l { color: var(--paper); }
#hero.h-swept .h-name-r { color: rgba(249,249,247,.4); }
#hero.h-swept .h-desc { color: rgba(249,249,247,.35); }
#hero.h-swept .h-cta { border-color: rgba(249,249,247,.25); color: var(--paper); }
#hero.h-swept .h-cta:hover { background: var(--paper); color: var(--ink); border-color: var(--paper); }
#hero.h-swept .h-scroll span { color: rgba(249,249,247,.3); }
#hero.h-swept .h-scroll-bar { background: linear-gradient(to bottom, rgba(249,249,247,.3), transparent); }

@keyframes up { from { opacity: 0; transform: translateY(32px); } to { opacity: 1; transform: translateY(0); } }
.h-foot {
  display: flex; justify-content: space-between; align-items: flex-end;
  animation: up .8s var(--ease) .55s both;
}
.h-foot-col { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
.h-foot-right { align-items: flex-end; }
.h-desc { font-size: .6rem; letter-spacing: .16em; text-transform: uppercase; line-height: 2; max-width: 220px; color: var(--muted); transition: color .6s var(--ease); }
.h-cta {
  font-size: .58rem; letter-spacing: .16em; text-transform: uppercase;
  padding: 10px 22px; text-decoration: none;
  border: 1px solid var(--ink); color: var(--ink);
  transition: background .3s, color .3s, border-color .5s;
}
.h-cta:hover { background: var(--ink); color: var(--paper); }

.h-scroll {
  position: absolute; bottom: clamp(24px,5vh,48px); left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  z-index: 2;
  animation: fade-in .8s var(--ease) 1.1s both;
}
.h-scroll span { font-size: .44rem; letter-spacing: .28em; text-transform: uppercase; color: var(--muted); writing-mode: vertical-rl; transition: color .6s var(--ease); }
.h-scroll-bar { width: 1px; height: 44px; background: linear-gradient(to bottom, var(--muted), transparent); animation: bar 2.2s ease-in-out 1.4s infinite; transition: background .6s var(--ease); }
@keyframes bar { 0% { transform: scaleY(0); transform-origin: top; } 50% { transform: scaleY(1); transform-origin: top; } 51% { transform-origin: bottom; } 100% { transform: scaleY(0); transform-origin: bottom; } }
@keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
@media (max-width: 640px) {
  .h-name { font-size: clamp(3.2rem, 14vw, 5.5rem); }
  .h-name-row {
    position: static;
    flex-direction: column;
    align-items: flex-start;
    padding: 0 var(--pad-x) 32px;
    gap: 0;
  }
  .h-foot { flex-direction: column; gap: 28px; }
  .h-foot-right { align-items: flex-start; }
  .h-scroll { display: none; }
}

/* ── SECTION SHELL ── */
.sec { padding: var(--pad-y) var(--pad-x); border-top: 1px solid var(--rule); }
.sec-inv { background: var(--ink); color: var(--paper); }
.sec-head {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: clamp(32px, 5vw, 64px);
  padding-bottom: clamp(20px, 3vw, 36px);
  border-bottom: 1px solid var(--rule);
}
.sec-inv .sec-head { border-color: rgba(249,249,247,.08); }
.sec-label { font-size: .52rem; letter-spacing: .26em; text-transform: uppercase; color: var(--muted); }
.sec-inv .sec-label { color: rgba(249,249,247,.35); }
.sec-title { font-family: var(--f-ser); font-size: clamp(2rem, 4.5vw, 4.5rem); font-weight: 300; line-height: .92; letter-spacing: -.02em; }
.sec-title em { font-style: italic; }
.sec-meta { font-size: .52rem; letter-spacing: .18em; color: var(--muted); }
.sec-inv .sec-meta { color: rgba(249,249,247,.25); }

/* ── WORK LAYOUT ── */
/* MAXIMALIST HORIZONTAL FILTER VERSION */
.work-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(24px, 4vw, 48px);
  align-items: start;
}

/* ── CATEGORY FILTER ── */
/* MAXIMALIST HORIZONTAL VERSION - BIG & BOLD */
.cat-filter {
  display: flex;
  flex-wrap: wrap;
  gap: clamp(8px, 1.5vw, 16px);
  padding: clamp(12px, 2vw, 24px) 0;
  margin-bottom: clamp(24px, 3vw, 40px);
  margin-left: 0;
  position: static;
  align-items: center;
}
/* MAXIMALIST BIG HORIZONTAL PILL VERSION */
.cat-pill {
  background: transparent;
  border: 2px solid var(--ink);
  color: var(--ink);
  font-family: var(--f-ser);
  font-size: clamp(1rem, 1.8vw, 1.6rem);
  font-weight: 700;
  letter-spacing: .04em;
  padding: clamp(18px, 2.2vw, 32px) clamp(24px, 3vw, 40px);
  cursor: none;
  position: relative;
  overflow: hidden;
  width: auto;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all .4s var(--ease);
  border-radius: 0;
}
.cat-pill::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .55s var(--ease);
  z-index: -1;
}
.cat-pill:hover {
  color: var(--ink);
  border-color: var(--accent);
  transform: scale(1.12);
  box-shadow: 0 8px 24px rgba(10, 10, 10, 0.12);
}
.cat-pill:hover::before { transform: scaleX(1); }
.cat-pill.is-active {
  background: var(--accent);
  color: var(--ink);
  border-color: var(--accent);
  box-shadow: 0 12px 32px rgba(0, 200, 100, 0.25);
  transform: scale(1.15);
  font-weight: 800;
}
.cat-pill.is-active::before { transform: scaleX(1); }

/* ── WORK GRID ── */
.proj-text-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  padding: 0;
}
.proj-item {
  background: var(--paper);
  text-decoration: none;
  color: var(--ink);
  position: relative;
  overflow: visible;
  cursor: none;
  min-height: 220px;
  transition: background .4s var(--ease);
  /* Default hidden state — JS adds .is-revealed to fade them in */
  opacity: 0;
  transform: translateY(18px);
}
.proj-item.is-revealed {
  animation: pi-reveal 600ms cubic-bezier(.25, .65, .35, 1) forwards;
  animation-delay: var(--reveal-delay, 0ms);
}
@keyframes pi-reveal {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.pi-inner {
  padding: clamp(20px, 2.5vw, 32px);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  min-height: inherit;
  position: relative;
  z-index: 1;
}
.proj-item.is-hidden { display: none; }

/* Border-tracing feedback — SVG with stroke-dashoffset
   draws a single continuous stroke clockwise around the card's
   true rectangular perimeter, then fades. */
.pi-border {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 4;
  opacity: 0;
  overflow: visible;
}
.pi-border-rect {
  stroke: var(--accent);
  stroke-width: 1;
  fill: none;
  /* stroke-dasharray + stroke-dashoffset get set inline via JS once we
     measure the card's real perimeter — that way the dash math is exact. */
}

/* Click feedback — quick flash + scale on press */
.proj-item.is-pressed {
  animation: pi-press 280ms ease-out forwards;
}
@keyframes pi-press {
  0%   { transform: scale(1); opacity: 1; }
  50%  { transform: scale(0.985); opacity: 0.85; }
  100% { transform: scale(1); opacity: 1; }
}
.proj-item.is-tracing .pi-border {
  opacity: 1;
  animation: pi-fade 1.6s ease-out forwards;
  animation-delay: var(--trace-delay, 0ms);
}
.proj-item.is-tracing .pi-border-rect {
  animation: pi-draw 950ms cubic-bezier(.55, .05, .25, 1) forwards;
  animation-delay: var(--trace-delay, 0ms);
}
@keyframes pi-draw {
  to { stroke-dashoffset: 0; }
}
@keyframes pi-fade {
  0%   { opacity: 1; }
  68%  { opacity: 1; }
  100% { opacity: 0; }
}

.proj-item::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--ink);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .55s var(--ease);
  z-index: 0;
}
.proj-item:hover::before { transform: scaleX(1); }
.proj-item > *:not(.pi-arr):not(.pi-border) { position: relative; z-index: 1; transition: color .3s; }
.pi-arr { position: absolute; z-index: 2; }

.pi-num {
  font-family: var(--f-ser);
  font-size: clamp(1.2rem, 2vw, 1.8rem);
  font-weight: 300;
  font-style: italic;
  color: rgba(10,10,10,.15);
  line-height: 1;
  margin-bottom: 16px;
}
.proj-item:hover .pi-num { color: rgba(249,249,247,.1); }

.pi-content { flex: 1; }
.pi-cat {
  font-size: .48rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 8px;
}
.proj-item:hover .pi-cat { color: rgba(249,249,247,.4); }

.pi-title {
  font-family: var(--f-ser);
  font-size: clamp(1.05rem, 1.8vw, 1.4rem);
  font-weight: 600;
  letter-spacing: -.01em;
  line-height: 1.2;
  color: var(--ink);
  margin-bottom: 10px;
}
.proj-item:hover .pi-title { color: var(--paper); }

.pi-meta {
  font-size: .5rem;
  letter-spacing: .1em;
  color: var(--muted);
  margin-bottom: 12px;
  line-height: 1.4;
}
.proj-item:hover .pi-meta { color: rgba(249,249,247,.3); }

.pi-badge {
  display: inline-block;
  font-size: .42rem;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: 4px 9px;
  background: var(--ink);
  color: var(--paper);
  transition: background .3s, color .3s;
}
.proj-item:hover .pi-badge { background: var(--paper); color: var(--ink); }

.pi-year {
  font-size: .48rem;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 12px;
}
.proj-item:hover .pi-year { color: rgba(249,249,247,.3); }

.pi-arr {
  position: absolute;
  right: clamp(8px, 1.5vw, 14px);
  bottom: clamp(8px, 1.5vw, 14px);
  width: 36px;
  height: 36px;
  border: 1px solid var(--rule);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .9rem;
  transition: background .4s, border-color .4s, transform .5s var(--ease), color .4s;
}
.proj-item:hover .pi-arr {
  background: var(--paper);
  border-color: var(--paper);
  color: var(--ink);
  transform: rotate(-42deg);
}

@media (max-width: 1100px) {
  .proj-text-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
  .cat-filter { gap: clamp(6px, 1vw, 10px); }
  .cat-pill { font-size: clamp(.9rem, 1.6vw, 1.2rem); padding: clamp(14px, 1.8vw, 24px) clamp(16px, 2.5vw, 28px); }
  .proj-text-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 780px) {
  .proj-text-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .work-layout { grid-template-columns: 1fr; }
  .cat-filter { flex-direction: row; flex-wrap: wrap; }
  .cat-pill { width: auto; }
  .proj-text-grid { grid-template-columns: 1fr; }
}

/* ── PROJECT HOVER PREVIEW ── */
#preview {
  position: fixed; pointer-events: none; z-index: 200;
  width: 260px; height: 160px;
  opacity: 0; transform: scale(.96);
  transition: opacity .3s var(--ease), transform .3s var(--ease);
  overflow: hidden;
  border: 1px solid rgba(10,10,10,.08);
}
#preview.show { opacity: 1; transform: scale(1); }
.pv-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--ink); }
.pv-num { font-family: var(--f-ser); font-size: 7rem; font-weight: 300; font-style: italic; color: rgba(249,249,247,.07); line-height: 1; user-select: none; pointer-events: none; }

/* ── ABOUT ── */
#about { background: var(--ink); }
.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 8vw, 100px); align-items: start; }
.ab-tagline { font-family: var(--f-ser); font-size: clamp(1.8rem, 3.5vw, 3.5rem); font-weight: 300; font-style: italic; line-height: 1.1; letter-spacing: -.02em; color: var(--paper); margin-top: 28px; }
.ab-body { margin-top: 32px; font-size: .78rem; line-height: 2; color: rgba(249,249,247,.45); }
.ab-body strong { color: var(--paper); font-weight: 700; }
.ab-body p + p { margin-top: 16px; }
.ab-tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 32px; }
.ab-downloads {
  display: flex;
  gap: 12px;
  margin-top: 28px;
  flex-wrap: wrap;
}
.ab-dl {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: .48rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 10px 20px;
  transition: background .3s, color .3s;
}
.ab-dl:hover {
  background: var(--accent);
  color: var(--ink);
}
.ab-dl-icon {
  font-size: .7rem;
  transition: transform .3s var(--ease);
}
.ab-dl:hover .ab-dl-icon { transform: translateY(2px); }
.ab-tag { font-size: .46rem; letter-spacing: .16em; text-transform: uppercase; padding: 7px 13px; border: 1px solid rgba(249,249,247,.08); color: rgba(249,249,247,.3); transition: border-color .3s, color .3s; }
.ab-tag:hover { border-color: rgba(249,249,247,.35); color: var(--paper); }
.ab-right { padding-top: clamp(40px, 6vw, 80px); }
.ab-facts { display: flex; flex-direction: column; }
.ab-fact { display: flex; justify-content: space-between; align-items: baseline; padding: 16px 0; border-bottom: 1px solid rgba(249,249,247,.06); gap: 16px; }
.ab-fact-k { font-size: .5rem; letter-spacing: .2em; text-transform: uppercase; color: rgba(249,249,247,.25); flex-shrink: 0; }
.ab-fact-v { font-family: var(--f-ser); font-size: .92rem; font-weight: 600; color: var(--paper); text-align: right; line-height: 1.3; }
.ab-fact-v.av { font-weight: 300; font-style: italic; color: rgba(249,249,247,.5); display: inline-flex; align-items: center; gap: 8px; }
.av-dot {
  display: inline-block;
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 0 0 rgba(0,255,156,.5);
  animation: av-pulse 2.4s ease-out infinite;
  flex-shrink: 0;
}
@keyframes av-pulse {
  0%   { box-shadow: 0 0 0 0 rgba(0,255,156,.55); }
  70%  { box-shadow: 0 0 0 8px rgba(0,255,156,0); }
  100% { box-shadow: 0 0 0 0 rgba(0,255,156,0); }
}
@media (max-width: 768px) {
  .ab-fact-v.av .av-text { display: none !important; }
}
@media (max-width: 768px) { .about-grid { grid-template-columns: 1fr; } .ab-right { padding-top: 40px; } }

/* ── CLIENTS ── */
#clients { background: var(--paper); }
.cl-text-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); }
.cl-text-item { background: var(--paper); padding: clamp(20px, 3vw, 32px); transition: background .3s; }
.cl-text-item:hover { background: var(--ink); }
.cl-n { font-size: .46rem; letter-spacing: .2em; color: var(--muted); margin-bottom: 12px; }
.cl-text-item:hover .cl-n { color: rgba(249,249,247,.25); }
.cl-name { font-family: var(--f-ser); font-size: clamp(.88rem, 1.4vw, 1rem); font-weight: 600; line-height: 1.3; color: var(--ink); margin-bottom: 8px; }
.cl-text-item:hover .cl-name { color: var(--paper); }
.cl-type { font-size: .46rem; letter-spacing: .18em; text-transform: uppercase; color: var(--muted); }
.cl-text-item:hover .cl-type { color: rgba(249,249,247,.3); }
@media (max-width: 900px) { .cl-text-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 480px) { .cl-text-grid { grid-template-columns: 1fr; } }

/* ── CONTACT ── */
#contact { background: var(--paper); padding: var(--pad-y) var(--pad-x); border-top: 1px solid var(--rule); }
.ct-inner { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 8vw, 100px); }
.ct-big { font-family: var(--f-ser); font-size: clamp(2.8rem, 7vw, 8rem); font-weight: 300; line-height: .88; letter-spacing: -.04em; color: var(--ink); margin-top: 20px; }
.ct-big em { font-style: italic; display: block; }
.ct-right { padding-top: clamp(20px, 4vw, 60px); }
.ct-row { display: flex; justify-content: space-between; align-items: center; padding: 18px 0; border-bottom: 1px solid var(--rule); text-decoration: none; color: var(--ink); transition: padding-left .4s var(--ease); cursor: none; gap: 12px; }
.ct-row:hover { padding-left: 12px; }
.ct-k { font-family: var(--f-ser); font-size: clamp(.9rem, 1.6vw, 1.2rem); font-weight: 600; letter-spacing: -.01em; color: var(--ink); transition: color .3s var(--ease); }
.ct-a { font-size: .9rem; color: var(--muted); transition: transform .4s var(--ease), color .3s; flex-shrink: 0; }
.ct-row:hover .ct-k { color: var(--accent); }
.ct-row:hover .ct-a { transform: translate(5px,-5px); color: var(--accent); }
@media (max-width: 768px) { .ct-inner { grid-template-columns: 1fr; } .ct-right { padding-top: 0; } }
</style>

<script>
// Reveal on scroll
const obs = new IntersectionObserver(
  (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); }),
  { threshold: 0.08 }
);
document.querySelectorAll('.r').forEach((el) => obs.observe(el));

// Hero scroll-driven dark sweep (same feel as project row hover)
const hero = document.getElementById('hero');
if (hero) {
  const updateHero = () => {
    const rect = hero.getBoundingClientRect();
    // Progress: 0 when hero fully visible, 1 when user has scrolled past ~60%
    const progress = Math.min(1, Math.max(0, -rect.top / (rect.height * 0.55)));
    hero.style.setProperty('--hero-sweep', progress.toFixed(3));
    hero.classList.toggle('h-swept', progress > 0.35);
  };
  window.addEventListener('scroll', updateHero, { passive: true });
  updateHero();
}

// Project hover preview
const preview = document.getElementById('preview');
const pvNum = document.getElementById('pvNum');
// Hover preview for project items
if (preview) {
  document.querySelectorAll('.proj-item').forEach((item) => {
    const heroSrc = item.getAttribute('data-hero');
    const num = item.querySelector('.pi-num')?.textContent?.trim() || '';
    item.addEventListener('mouseenter', () => {
      if (pvNum) pvNum.textContent = num;
      if (heroSrc) {
        const img = new Image();
        img.className = 'pv-img';
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;';
        img.onload = () => preview.appendChild(img);
        img.src = heroSrc;
      }
      preview.classList.add('show');
    });
    item.addEventListener('mouseleave', () => {
      preview.classList.remove('show');
      preview.querySelectorAll('.pv-img').forEach((i) => i.remove());
    });
    item.addEventListener('mousemove', (e) => {
      preview.style.left = (e.clientX + 20) + 'px';
      preview.style.top = (e.clientY - 80) + 'px';
    });
  });
}

// Category filter
const catPills = document.querySelectorAll('.cat-pill');
const projItems = document.querySelectorAll('.proj-item');

// Click feedback — flash + scale + brief border pulse before navigating away
projItems.forEach((item) => {
  item.addEventListener('click', (e) => {
    // Delay the navigation slightly so the user sees the feedback
    if (item.classList.contains('is-pressed')) return;
    const href = item.getAttribute('href');
    if (!href) return;
    // Let the user see the press animation; ~200ms is enough
    if (!e.metaKey && !e.ctrlKey && !e.shiftKey && e.button === 0) {
      e.preventDefault();
      item.classList.add('is-pressed');
      // Re-pulse the border briefly for extra confirmation
      item.style.setProperty('--trace-delay', '0ms');
      item.classList.remove('is-tracing');
      void item.offsetWidth;
      item.classList.add('is-tracing');
      setTimeout(() => { window.location.href = href; }, 230);
    }
  });
});

// Measure each card and set its stroke-dasharray / stroke-dashoffset to
// its actual perimeter so the SVG draws a single clean clockwise pass.
function setupBorderPaths() {
  projItems.forEach((item) => {
    const r = item.getBoundingClientRect();
    if (r.width === 0 || r.height === 0) return;
    const perimeter = 2 * (r.width + r.height);
    const rectEl = item.querySelector('.pi-border-rect');
    if (rectEl) {
      rectEl.style.strokeDasharray = perimeter + 'px';
      rectEl.style.strokeDashoffset = perimeter + 'px';
    }
  });
}

// Trigger the reveal + border-tracing animation on every currently-visible
// item, staggered row-by-row, left-to-right within each row.
function revealAndTraceVisibleItems() {
  setupBorderPaths();          // refresh dimensions in case anything reflowed
  // Clear any in-flight state first so animations restart cleanly
  projItems.forEach((item) => {
    item.classList.remove('is-tracing');
    item.classList.remove('is-revealed');
  });
  // Force reflow so the next class addition restarts the keyframes/transitions
  void document.body.offsetWidth;

  const COL_STAGGER = 90;    // ms between cards in the same row (reveal pace)
  const ROW_STAGGER = 220;   // ms between rows

  // Collect visible items with their grid position, group into rows
  const visible = Array.from(projItems)
    .filter((item) => !item.classList.contains('is-hidden'))
    .map((item) => {
      const r = item.getBoundingClientRect();
      return { item, top: Math.round(r.top), left: Math.round(r.left) };
    })
    .sort((a, b) => {
      if (Math.abs(a.top - b.top) > 5) return a.top - b.top;
      return a.left - b.left;
    });

  let currentRowTop = -Infinity;
  let rowIdx = -1;
  let colIdx = 0;

  visible.forEach(({ item, top }) => {
    if (Math.abs(top - currentRowTop) > 5) {
      rowIdx++;
      colIdx = 0;
      currentRowTop = top;
    } else {
      colIdx++;
    }
    const delay = rowIdx * ROW_STAGGER + colIdx * COL_STAGGER;
    item.style.setProperty('--reveal-delay', delay + 'ms');
    item.style.setProperty('--trace-delay', delay + 'ms');
    item.classList.add('is-revealed');
    item.classList.add('is-tracing');
    setTimeout(() => item.classList.remove('is-tracing'), 1700 + delay);
  });
}

// Keep the old name as an alias so other call sites still work
const traceVisibleItems = revealAndTraceVisibleItems;

// Recompute on window resize (debounced) — cards can reflow with the grid
let __resizeTimer = null;
window.addEventListener('resize', () => {
  clearTimeout(__resizeTimer);
  __resizeTimer = setTimeout(setupBorderPaths, 200);
});

catPills.forEach((pill) => {
  pill.addEventListener('click', () => {
    const cat = pill.getAttribute('data-cat');
    catPills.forEach((p) => p.classList.remove('is-active'));
    pill.classList.add('is-active');
    projItems.forEach((item) => {
      if (cat === 'All') {
        item.classList.remove('is-hidden');
        return;
      }
      const cats = (item.getAttribute('data-cats') || '').split('||');
      if (cats.includes(cat)) item.classList.remove('is-hidden');
      else item.classList.add('is-hidden');
    });
    traceVisibleItems();
  });
});

// Trigger reveal+trace only when the work grid scrolls into view (once).
// If the grid is already in view at page load, this fires immediately.
function setupWorkSectionObserver() {
  const grid = document.getElementById('proj-grid');
  if (!grid) return;
  let hasFired = false;
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting && !hasFired) {
        hasFired = true;
        setupBorderPaths();
        setTimeout(traceVisibleItems, 80);
        obs.disconnect();
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });
  obs.observe(grid);
}

if (document.readyState === 'complete' || document.readyState === 'interactive') {
  setupWorkSectionObserver();
} else {
  window.addEventListener('DOMContentLoaded', setupWorkSectionObserver);
}
</script>
