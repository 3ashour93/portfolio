---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import { PROFILE } from '../data/projects';

interface Props {
  title?: string;
  description?: string;
  showBack?: boolean;
}

const {
  title = 'Omar Ashour — Creative Director & Brand Designer',
  description = 'Senior Creative Director & Brand Designer based in Doha, Qatar. 8+ years directing brand identities, event campaigns, and digital experiences for QICDRC, AFC Asian Cup, Design Doha Biennial and more.',
  showBack = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
  <Cursor />
  <Nav showBack={showBack} profile={PROFILE} />
  <slot />
  <Footer profile={PROFILE} />
</body>
</html>
